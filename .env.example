# SnapWild Environment Variables
# Copy this file to .env and fill in your keys

# Gemini AI — get yours at https://aistudio.google.com/app/apikey
# Without this key, the app runs in demo mode (returns Indian Peacock for every photo)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps — configured in app.json under ios.config and android.config
# Key is already set in app.json for both platforms
